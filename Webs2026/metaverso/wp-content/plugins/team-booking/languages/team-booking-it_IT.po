msgid_plural "%d days before (until midnight)"
msgstr[0] "%d giorno prima (fino a mezzanotte)"
msgstr[1] "%d giorni prima (fino a mezzanotte)"

#: Settings/Service/Personal_WhenToCloseReference.php:25
