{"files":[{"id":"4c0da96a-8098-48dc-93b1-d91bebd7f862","name":"appsscript","type":"json","source":"{\n  \"timeZone\": \"America/Santiago\",\n  \"dependencies\": {},\n  \"exceptionLogging\": \"STACKDRIVER\",\n  \"runtimeVersion\": \"V8\",\n  \"webapp\": {\n    \"executeAs\": \"USER_DEPLOYING\",\n    \"access\": \"ANYONE_ANONYMOUS\"\n  }\n}"},{"id":"6cc94d06-2f93-4047-89c8-95705f02c05c","name":"Code","type":"server_js","source":"/**\n * Code.gs completo para el Dashboard (RUT único, fechas robustas y distribución por cursos únicos)\n * Encabezados esperados (exactos), pero con tolerancia:\n * Fecha | Nombre | Apellido | Correo | RUT | Género | Edad | Empresa | Cargo |\n * Correctas | Totales | Porcentaje | Tiempo Total (seg) | Tiempo Total (HH:MM:SS) |\n * Firma (base64) | Certificado | Cursos\n */\n\n/* \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d CONFIG \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d */\nconst SHEET_ID \u003d \u00271jnIPE6d0fyHZTGxpu0RiYDFwMfii-1Rb8DckRB1mBJA\u0027;\nconst RESPONSES_SHEET_NAME \u003d \u0027Respuestas\u0027;\n\n/* \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d Helpers \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d */\nfunction normCourseName_(c){ if(c\u003d\u003dnull) return \u0027\u0027; return String(c).normalize(\u0027NFD\u0027).replace(/[\\u0300-\\u036f]/g,\u0027\u0027).replace(/\\s+/g,\u0027 \u0027).trim(); }\n\nfunction toNumberOrNull_(v){ const n\u003dNumber(v); return (isFinite(n)\u0026\u0026!isNaN(n))?n:null; }\nfunction indexByExact_(hdr, name){ return hdr.findIndex(h \u003d\u003e String(h??\u0027\u0027).trim()\u003d\u003d\u003dname); }\n/** Busca una columna por coincidencia parcial (case-insensitive) del término dado. */\nfunction indexByContains_(hdr, term){\n  const t \u003d term.toLowerCase();\n  return hdr.findIndex(h \u003d\u003e String(h??\u0027\u0027).toLowerCase().includes(t));\n}\n\n/**\n * Parser de fechas robusto:\n * - Date nativo\n * - Strings ISO\n * - Strings dd/MM/yyyy o dd-MM-yyyy (con o sin HH:mm:ss)\n * - Números seriales de Sheets/Excel\n * Devuelve YYYY-MM-DD o null si no puede parsear.\n */\nfunction formatDateOnly_(d){\n  if (!d \u0026\u0026 d !\u003d\u003d 0) return null;\n\n  // Date nativo\n  if (Object.prototype.toString.call(d) \u003d\u003d\u003d \u0027[object Date]\u0027 \u0026\u0026 !isNaN(d.getTime())) {\n    const y\u003dd.getFullYear(), m\u003dString(d.getMonth()+1).padStart(2,\u00270\u0027), da\u003dString(d.getDate()).padStart(2,\u00270\u0027);\n    return `${y}-${m}-${da}`;\n  }\n\n  // Serial numérico de Sheets/Excel (días desde 1899-12-30)\n  if (typeof d \u003d\u003d\u003d \u0027number\u0027 \u0026\u0026 isFinite(d)) {\n    const ms \u003d Math.round((d - 25569) * 86400 * 1000); // 25569 \u003d 1970-01-01\n    const dt \u003d new Date(ms);\n    if (!isNaN(dt.getTime())) {\n      const y\u003ddt.getFullYear(), m\u003dString(dt.getMonth()+1).padStart(2,\u00270\u0027), da\u003dString(dt.getDate()).padStart(2,\u00270\u0027);\n      return `${y}-${m}-${da}`;\n    }\n  }\n\n  // String\n  if (typeof d \u003d\u003d\u003d \u0027string\u0027) {\n    const s \u003d d.trim();\n\n    // dd/MM/yyyy o dd-MM-yyyy con o sin hora\n    const m \u003d s.match(/^(\\d{1,2})[\\/\\-](\\d{1,2})[\\/\\-](\\d{2,4})(?:\\s+(\\d{1,2}):(\\d{2})(?::(\\d{2}))?)?$/);\n    if (m) {\n      const dd \u003d parseInt(m[1],10), MM \u003d parseInt(m[2],10), yyyy \u003d parseInt(m[3].length\u003d\u003d\u003d2?(\u002720\u0027+m[3]):m[3],10);\n      if (yyyy\u003e\u003d1900 \u0026\u0026 MM\u003e\u003d1 \u0026\u0026 MM\u003c\u003d12 \u0026\u0026 dd\u003e\u003d1 \u0026\u0026 dd\u003c\u003d31) {\n        return `${yyyy}-${String(MM).padStart(2,\u00270\u0027)}-${String(dd).padStart(2,\u00270\u0027)}`;\n      }\n    }\n\n    // Intento final con Date\n    const tmp \u003d new Date(s);\n    if (!isNaN(tmp.getTime())) {\n      const y\u003dtmp.getFullYear(), m\u003dString(tmp.getMonth()+1).padStart(2,\u00270\u0027), da\u003dString(tmp.getDate()).padStart(2,\u00270\u0027);\n      return `${y}-${m}-${da}`;\n    }\n  }\n\n  return null;\n}\n\n/**\n * Normaliza RUT: quita puntos/espacios, mayúsculas y devuelve XXXXXXXX-D (o K).\n * Si no hay RUT válido, retorna \u0027\u0027.\n */\nfunction normalizeRut_(rut) {\n  if (rut \u003d\u003d null) return \u0027\u0027;\n  let s \u003d String(rut).toUpperCase().replace(/\\s+/g, \u0027\u0027);\n  s \u003d s.replace(/\\./g, \u0027\u0027).replace(/-/g, \u0027\u0027);\n  s \u003d s.replace(/[^0-9K]/g, \u0027\u0027);\n  if (s.length \u003c 2) return \u0027\u0027;\n  const dv \u003d s.slice(-1);\n  let num \u003d s.slice(0, -1).replace(/^0+/, \u0027\u0027);\n  if (!num) return \u0027\u0027;\n  return `${num}-${dv}`;\n}\n\n/* \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d HTML \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d */\nfunction doGet(e){\n  const t \u003d HtmlService.createTemplateFromFile(\u0027index\u0027); // index.html\n  t.SHEET_ID \u003d SHEET_ID;\n  return t.evaluate().setTitle(\u0027Dashboard Sacyr Chile S.A.\u0027).setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);\n}\n\n/* \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d DATA API \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d */\nfunction getDashboardData(e){\n  const params \u003d (e\u0026\u0026e.parameter)?e.parameter:{};\n  const startDateParam \u003d params.startDate || null;\n  const endDateParam   \u003d params.endDate   || null;\n  const onlyCompleted  \u003d (params.onlyCompleted\u003d\u003d\u003d\u0027true\u0027 || params.onlyCompleted\u003d\u003d\u003dtrue);\n\n  const ss \u003d SpreadsheetApp.openById(SHEET_ID);\n  const sh \u003d ss.getSheetByName(RESPONSES_SHEET_NAME);\n  if(!sh) throw new Error(\u0027No se encontró la hoja \"\u0027+RESPONSES_SHEET_NAME+\u0027\". Actualiza RESPONSES_SHEET_NAME en Code.gs\u0027);\n\n  const values \u003d sh.getDataRange().getValues();\n  if(!values || values.length\u003c2){\n    return { totals:{ totalResponses:0, totalStudents:0, uniqueStudents:0, students8Plus:0 },\n             dailyActivity:[], coursesDetected:[], demographics:{}, students:[], coursesPerStudent:[] };\n  }\n\n  const header \u003d values[0].map(h \u003d\u003e (h\u003d\u003dnull?\u0027\u0027:String(h).trim()));\n  const rows   \u003d values.slice(1);\n\n  // Índices (exacto y fallback por contains)\n  let idxFecha        \u003d indexByExact_(header,\u0027Fecha\u0027);        if (idxFecha \u003c 0)        idxFecha \u003d indexByContains_(header,\u0027fecha\u0027);\n  let idxRUT          \u003d indexByExact_(header,\u0027RUT\u0027);          if (idxRUT \u003c 0)          idxRUT   \u003d indexByContains_(header,\u0027rut\u0027);\n  let idxGenero       \u003d indexByExact_(header,\u0027Género\u0027);       if (idxGenero \u003c 0)       idxGenero\u003d indexByContains_(header,\u0027género\u0027);\n  let idxEdad         \u003d indexByExact_(header,\u0027Edad\u0027);         if (idxEdad \u003c 0)         idxEdad  \u003d indexByContains_(header,\u0027edad\u0027);\n  let idxCorrectas    \u003d indexByExact_(header,\u0027Correctas\u0027);    if (idxCorrectas \u003c 0)    idxCorrectas \u003d indexByContains_(header,\u0027correctas\u0027);\n  let idxTotales      \u003d indexByExact_(header,\u0027Totales\u0027);      if (idxTotales \u003c 0)      idxTotales   \u003d indexByContains_(header,\u0027totales\u0027);\n  let idxPorcentaje   \u003d indexByExact_(header,\u0027Porcentaje\u0027);   if (idxPorcentaje \u003c 0)   idxPorcentaje\u003d indexByContains_(header,\u0027porcentaje\u0027);\n  let idxCertificado  \u003d indexByExact_(header,\u0027Certificado\u0027);  if (idxCertificado \u003c 0)  idxCertificado\u003d indexByContains_(header,\u0027cert\u0027);\n  let idxCursos       \u003d indexByExact_(header,\u0027Cursos\u0027);       if (idxCursos \u003c 0)       idxCursos    \u003d indexByContains_(header,\u0027curso\u0027);\n\n  // Parse filas\n  const parsedRows \u003d rows.map(r\u003d\u003e{\n    const ts   \u003d idxFecha\u003e\u003d0 ? r[idxFecha] : null;\n    const date \u003d formatDateOnly_(ts);\n\n    const rutRaw \u003d idxRUT\u003e\u003d0 ? r[idxRUT] : \u0027\u0027;\n    const rutN   \u003d normalizeRut_(rutRaw); // \u003c- RUT normalizado\n\n    const gender \u003d idxGenero\u003e\u003d0 ? String(r[idxGenero]??\u0027\u0027).trim() : \u0027\u0027;\n    const age    \u003d idxEdad\u003e\u003d0 ? toNumberOrNull_(r[idxEdad]) : null;\n\n    const correctas \u003d idxCorrectas\u003e\u003d0 ? toNumberOrNull_(r[idxCorrectas]) : null;\n    const totales   \u003d idxTotales\u003e\u003d0   ? toNumberOrNull_(r[idxTotales])   : null;\n    let nota        \u003d idxPorcentaje\u003e\u003d0 ? toNumberOrNull_(r[idxPorcentaje]) : null;\n    if(nota\u003d\u003d\u003dnull \u0026\u0026 correctas!\u003d\u003dnull \u0026\u0026 totales){ nota \u003d (correctas/totales)*100; }\n\n    const certificado \u003d idxCertificado\u003e\u003d0 ? String(r[idxCertificado]??\u0027\u0027).trim().toLowerCase() : \u0027\u0027;\n    const cursosRaw   \u003d idxCursos\u003e\u003d0 ? String(r[idxCursos]??\u0027\u0027) : \u0027\u0027;\n\n    return { rawTimestamp: ts, date, rutN, gender, age, nota, certificado, cursosRaw };\n  });\n\n  // Filtros por fecha (si vinieran parámetros)\n  let filteredRows \u003d parsedRows;\n  if(startDateParam){\n    const sd \u003d new Date(startDateParam+\u0027T00:00:00\u0027);\n    filteredRows \u003d filteredRows.filter(rr \u003d\u003e {\n      const dt \u003d (rr.rawTimestamp \u0026\u0026 Object.prototype.toString.call(rr.rawTimestamp) \u003d\u003d\u003d \u0027[object Date]\u0027 \u0026\u0026 !isNaN(rr.rawTimestamp.getTime()))\n        ? rr.rawTimestamp\n        : (rr.date ? new Date(rr.date+\u0027T00:00:00\u0027) : null);\n      return dt ? dt \u003e\u003d sd : false;\n    });\n  }\n  if(endDateParam){\n    const ed \u003d new Date(endDateParam+\u0027T23:59:59\u0027);\n    filteredRows \u003d filteredRows.filter(rr \u003d\u003e {\n      const dt \u003d (rr.rawTimestamp \u0026\u0026 Object.prototype.toString.call(rr.rawTimestamp) \u003d\u003d\u003d \u0027[object Date]\u0027 \u0026\u0026 !isNaN(rr.rawTimestamp.getTime()))\n        ? rr.rawTimestamp\n        : (rr.date ? new Date(rr.date+\u0027T00:00:00\u0027) : null);\n      return dt ? dt \u003c\u003d ed : false;\n    });\n  }\n\n  if(onlyCompleted){\n    filteredRows \u003d filteredRows.filter(rr\u003d\u003e{\n      const v\u003d(rr.certificado||\u0027\u0027).toLowerCase();\n      return [\u0027si\u0027,\u0027sí\u0027,\u0027yes\u0027,\u0027true\u0027,\u0027completed\u0027,\u0027complete\u0027,\u00271\u0027,\u0027ok\u0027,\u0027emitido\u0027].includes(v) || v.indexOf(\u0027cert\u0027)\u003d\u003d\u003d0;\n    });\n  }\n\n  // Agregaciones (RUT siempre requerido; \u0027date\u0027 solo para actividad diaria y students)\n  const totalResponses \u003d filteredRows.length;\n  const studentSet \u003d new Set();              // set de RUT normalizados\n  const uniqueCoursesByRut \u003d {};             // RUT -\u003e Set(cursos únicos)\n  const courseAgg \u003d {};                      // curso -\u003e {sum,count,responses}\n  const dailyStudentSets \u003d {};               // date -\u003e Set(RUT)\n  const studentDayAgg \u003d {};                  // (RUT|date) -\u003e {rut,date,sumNota,countNota,totalCursos,gender,age}\n\n  filteredRows.forEach(rr\u003d\u003e{\n    if(!rr.rutN) return;                     // ignorar registros sin RUT\n    const rut \u003d rr.rutN;\n    studentSet.add(rut);\n\n    const cursos \u003d String(rr.cursosRaw||\u0027\u0027)\n      .split(/[,;|\\/\\n]+/)\n      .map(s\u003d\u003enormCourseName_(s))\n      .filter(Boolean);\n\n    if(!uniqueCoursesByRut[rut]) uniqueCoursesByRut[rut] \u003d new Set();\n    cursos.forEach(c\u003d\u003e uniqueCoursesByRut[rut].add(c));\n\n    cursos.forEach(c\u003d\u003e{\n      if(!courseAgg[c]) courseAgg[c]\u003d{sum:0,count:0,responses:0};\n      courseAgg[c].responses +\u003d 1;\n      if(rr.nota!\u003d\u003dnull){ courseAgg[c].sum +\u003d rr.nota; courseAgg[c].count +\u003d 1; }\n    });\n\n    // Solo para agregados diarios si hay fecha válida\n    if (rr.date) {\n      const dateKey \u003d rr.date;\n      const key \u003d rut+\u0027|\u0027+dateKey;\n      if(!studentDayAgg[key]) studentDayAgg[key] \u003d { rut, date:dateKey, sumNota:0, countNota:0, totalCursos:0, gender: rr.gender||\u0027\u0027, age: rr.age };\n      studentDayAgg[key].totalCursos +\u003d cursos.length;\n      if(rr.nota!\u003d\u003dnull){ studentDayAgg[key].sumNota +\u003d rr.nota; studentDayAgg[key].countNota +\u003d 1; }\n\n      if(!dailyStudentSets[dateKey]) dailyStudentSets[dateKey] \u003d new Set();\n      dailyStudentSets[dateKey].add(rut);\n    }\n  });\n\n  const dailyActivity \u003d Object.keys(dailyStudentSets)\n    .filter(Boolean) // descarta null/undefined\n    .sort((a,b)\u003d\u003e a.localeCompare(b))\n    .map(dateKey\u003d\u003e{\n      const ruts \u003d dailyStudentSets[dateKey];\n      let eight \u003d 0;\n      ruts.forEach(r \u003d\u003e { if((uniqueCoursesByRut[r]?.size || 0) \u003e\u003d 8) eight +\u003d 1; });\n      return { date: dateKey, uniqueStudents: ruts.size, students8Plus: eight };\n    });\n\n  const coursesDetected \u003d Object.keys(courseAgg).map(name\u003d\u003e{\n    const a \u003d courseAgg[name];\n    const avg \u003d a.count\u003e0 ? a.sum/a.count : null;\n    return { course:name, avg: avg\u003d\u003d\u003dnull ? null : Number(avg.toFixed(4)), n: a.count, responses: a.responses };\n  }).sort((x,y)\u003d\u003e{\n    if(x.avg\u003d\u003d\u003dnull \u0026\u0026 y.avg\u003d\u003d\u003dnull) return 0;\n    if(x.avg\u003d\u003d\u003dnull) return 1;\n    if(y.avg\u003d\u003d\u003dnull) return -1;\n    return y.avg - x.avg;\n  });\n\n  const students \u003d Object.values(studentDayAgg).map(s\u003d\u003e({\n    RUT: s.rut,\n    Género: s.gender || \u0027No declarado\u0027,\n    Edad: s.age,\n    Fecha: s.date,\n    TotalCursos: s.totalCursos,\n    PromedioNota: s.countNota ? Number((s.sumNota/s.countNota).toFixed(2)) : null\n  }));\n\n  // NUEVO: total de cursos únicos por RUT (para distribución correcta)\n  const coursesPerStudent \u003d Object.entries(uniqueCoursesByRut).map(([rut, set]) \u003d\u003e ({\n    RUT: rut,\n    TotalCursos: set.size\n  }));\n\n  const demographics \u003d { gender:{}, ageBuckets:{} };\n  students.forEach(s\u003d\u003e{\n    const g \u003d s.Género || \u0027No declarado\u0027;\n    demographics.gender[g] \u003d (demographics.gender[g]||0)+1;\n    const a \u003d toNumberOrNull_(s.Edad);\n    let bucket\u003d\u0027No declarado\u0027;\n    if(a!\u003d\u003dnull) bucket \u003d a\u003c18?\u0027\u003c18\u0027:a\u003c25?\u002718-24\u0027:a\u003c35?\u002725-34\u0027:a\u003c50?\u002735-49\u0027:\u002750+\u0027;\n    demographics.ageBuckets[bucket] \u003d (demographics.ageBuckets[bucket]||0)+1;\n  });\n\n  const students8Plus \u003d coursesPerStudent.filter(x \u003d\u003e x.TotalCursos \u003e\u003d 8).length;\n  const totals \u003d {\n    totalResponses,\n    totalStudents: studentSet.size,\n    uniqueStudents: studentSet.size,\n    students8Plus\n  };\n\n  return { totals, dailyActivity, coursesDetected, demographics, students, coursesPerStudent,\n           meta: { filteredRowsCount: filteredRows.length, originalHeader: header } };\n}"},{"id":"a4e35b29-a19a-46a5-a8ea-333c7146b0ad","name":"index","type":"html","source":"\u003c!doctype html\u003e\n\u003chtml lang\u003d\"es\"\u003e\n\u003chead\u003e\n  \u003cmeta charset\u003d\"utf-8\" /\u003e\n  \u003cmeta name\u003d\"viewport\" content\u003d\"width\u003ddevice-width,initial-scale\u003d1\" /\u003e\n  \u003ctitle\u003eDashboard Sacyr Chile S.A.\u003c/title\u003e\n  \u003cscript src\u003d\"https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js\"\u003e\u003c/script\u003e\n\n  \u003cstyle\u003e\n    :root{\n      /* Paleta Dark */\n      --bg: #0B1220;              /* fondo app */\n      --surface: #0f172a;         /* tarjetas */\n      --surface-2: #0b1326;       /* header / barras */\n      --on-bg: #E2E8F0;           /* texto principal */\n      --on-muted: #94A3B8;        /* texto secundario */\n      --border: rgba(148,163,184,.12);\n      --border-strong: rgba(148,163,184,.22);\n\n      --primary: #60a5fa;         /* azul */\n      --primary-2: #22d3ee;       /* cian */\n      --accent: #a78bfa;          /* violeta */\n      --danger: #ef4444;          /* rojo */\n\n      --radius: 12px;\n      --shadow: 0 0 0 1px var(--border), 0 8px 24px rgba(2,6,23,.35);\n      --gap: 16px;\n      --pad: 14px;\n\n      --chart-h: 260px;\n    }\n\n    /* App */\n    *{ box-sizing: border-box; }\n    html, body { height: 100%; }\n    body{\n      margin:0; padding:18px;\n      font-family: ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      color: var(--on-bg);\n      background: radial-gradient(1200px 600px at 0% -20%, rgba(96,165,250,.15), transparent 60%),\n                  radial-gradient(1200px 600px at 100% 120%, rgba(34,211,238,.12), transparent 60%),\n                  var(--bg);\n    }\n\n    header{\n      display:flex; align-items:center; gap:12px; margin-bottom:12px;\n      background: linear-gradient(180deg, rgba(255,255,255,.02), rgba(255,255,255,0));\n      border-radius: var(--radius);\n      padding:10px 12px;\n      box-shadow: var(--shadow);\n    }\n    h1{ font-size:16px; font-weight:700; margin:0; color:#f8fafc;}\n    .controls{ margin-left:auto; display:flex; gap:8px; align-items:center; flex-wrap:wrap; }\n\n    /* Inputs / botones estilo “chip” */\n    .chip{\n      background: var(--surface);\n      border: 1px solid var(--border);\n      color: var(--on-bg);\n      padding:8px 10px; border-radius:10px; font-size:13px;\n      box-shadow: 0 2px 8px rgba(0,0,0,.25) inset;\n    }\n    input[type\u003d\"date\"].chip{\n      outline: none;\n    }\n    .btn{\n      border:1px solid var(--border);\n      color: var(--on-bg);\n      background: linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.02));\n      padding:8px 12px; border-radius:10px; font-weight:600; font-size:13px;\n      cursor:pointer;\n    }\n    .btn.primary{\n      border-color: rgba(96,165,250,.35);\n      background: linear-gradient(180deg, rgba(96,165,250,.35), rgba(96,165,250,.10));\n      color:#eaf2ff;\n    }\n    .btn.ghost{\n      background: transparent;\n    }\n    .btn:hover{ filter: brightness(1.08); }\n\n    /* Widgets */\n    .stats{\n      display:grid; grid-template-columns: repeat(2, minmax(220px,1fr));\n      gap: var(--gap); margin: 12px 0;\n    }\n    .stat-card{\n      background: linear-gradient(180deg, rgba(255,255,255,.02), rgba(255,255,255,0));\n      border: 1px solid var(--border);\n      border-radius: var(--radius); padding:14px;\n      box-shadow: var(--shadow);\n    }\n    .stat-title{ font-size:12px; color: var(--on-muted); margin-bottom:6px; }\n    .stat-value{ font-size:30px; font-weight:800; letter-spacing:.3px; color:#f8fafc; }\n    .stat-sub{ font-size:12px; color: var(--on-muted); margin-top:4px; }\n\n    /* Tarjetas contenedoras */\n    .grid{ display:grid; grid-template-columns: repeat(2, 1fr); gap: var(--gap); }\n    .card{\n      background: var(--surface);\n      border: 1px solid var(--border);\n      border-radius: var(--radius); padding: var(--pad);\n      box-shadow: var(--shadow);\n      min-height: 120px;\n      display:flex; flex-direction:column; gap:8px;\n    }\n    .card h3{ margin:0; font-size:14px; color:#e5e7eb; }\n    .card .meta{ font-size:12px; color: var(--on-muted); }\n\n    /* Chart containers */\n    .chart-wrap{ height: var(--chart-h); overflow-x:auto; overflow-y:hidden; }\n    .chart-wrap canvas{ display:block; }\n    .chart-wrap.courses{ height: 400px; overflow-y:auto; overflow-x:hidden; }\n\n    /* Debug */\n    pre.debug{\n      max-height:180px; overflow:auto;\n      background:#0b1220; color:#d1fae5; padding:10px; border-radius:10px;\n      border:1px solid var(--border);\n      box-shadow: var(--shadow); font-size:12px;\n    }\n\n    /* Scrollbar */\n    ::-webkit-scrollbar{ height:10px; width:10px; }\n    ::-webkit-scrollbar-thumb{ background: rgba(148,163,184,.25); border-radius:10px; }\n    ::-webkit-scrollbar-track{ background: rgba(148,163,184,.08); border-radius:10px; }\n\n    @media (max-width:980px){ .grid{ grid-template-columns:1fr; } .stats{ grid-template-columns:1fr 1fr; } }\n    @media (max-width:560px){ .stats{ grid-template-columns:1fr; } }\n  \u003c/style\u003e\n\u003c/head\u003e\n\u003cbody\u003e\n  \u003cheader\u003e\n    \u003ch1\u003eDashboard de Cursos\u003c/h1\u003e\n    \u003cdiv class\u003d\"controls\"\u003e\n      \u003clabel for\u003d\"dateFilter\" style\u003d\"font-size:13px;color:var(--on-muted)\"\u003eFiltrar por fecha:\u003c/label\u003e\n      \u003cinput id\u003d\"dateFilter\" type\u003d\"date\" class\u003d\"chip\" /\u003e\n      \u003cbutton id\u003d\"applyFilterBtn\" class\u003d\"btn primary\" title\u003d\"Aplicar filtro\"\u003eAplicar\u003c/button\u003e\n      \u003cbutton id\u003d\"resetFilterBtn\" class\u003d\"btn\" title\u003d\"Quitar filtros\"\u003eReset\u003c/button\u003e\n      \u003cbutton id\u003d\"exportDataBtn\" class\u003d\"btn ghost\" title\u003d\"Exportar payload a JSON/CSV\"\u003eExportar datos\u003c/button\u003e\n    \u003c/div\u003e\n  \u003c/header\u003e\n\n  \u003c!-- Widgets --\u003e\n  \u003cdiv class\u003d\"stats\" id\u003d\"statsRow\" style\u003d\"display:none;\"\u003e\n    \u003cdiv class\u003d\"stat-card\"\u003e\n      \u003cdiv class\u003d\"stat-title\"\u003eAlumnos únicos totales\u003c/div\u003e\n      \u003cdiv class\u003d\"stat-value\" id\u003d\"statUnique\"\u003e—\u003c/div\u003e\n    \u003c/div\u003e\n    \u003cdiv class\u003d\"stat-card\"\u003e\n      \u003cdiv class\u003d\"stat-title\"\u003eAlumnos con 8 cursos completados\u003c/div\u003e\n      \u003cdiv class\u003d\"stat-value\" id\u003d\"stat8\"\u003e—\u003c/div\u003e\n      \u003cdiv class\u003d\"stat-sub\" id\u003d\"stat8pct\"\u003e—\u003c/div\u003e\n    \u003c/div\u003e\n  \u003c/div\u003e\n\n  \u003cdiv id\u003d\"loader\" class\u003d\"stat-title\" style\u003d\"margin-bottom:12px\"\u003eCargando datos…\u003c/div\u003e\n\n  \u003cdiv class\u003d\"grid\" id\u003d\"dashboardGrid\" style\u003d\"display:none;\"\u003e\n    \u003cdiv class\u003d\"card\"\u003e\n      \u003ch3\u003eActividad diaria\u003c/h3\u003e\n      \u003cdiv class\u003d\"meta\"\u003eAlumnos únicos (barras) y alumnos ≥8 (línea). Haz click en una barra para filtrar por día.\u003c/div\u003e\n      \u003cdiv class\u003d\"chart-wrap\"\u003e\u003ccanvas id\u003d\"chartDaily\"\u003e\u003c/canvas\u003e\u003c/div\u003e\n    \u003c/div\u003e\n\n    \u003cdiv class\u003d\"card\"\u003e\n      \u003ch3\u003eDistribución - Total cursos por alumno\u003c/h3\u003e\n      \u003cdiv class\u003d\"meta\"\u003eCursos únicos por RUT\u003c/div\u003e\n      \u003cdiv class\u003d\"chart-wrap\"\u003e\u003ccanvas id\u003d\"chartDistribution\"\u003e\u003c/canvas\u003e\u003c/div\u003e\n      \u003cdiv id\u003d\"distSummary\" class\u003d\"meta\" style\u003d\"margin-top:8px\"\u003e\u003c/div\u003e\n    \u003c/div\u003e\n\n    \u003cdiv class\u003d\"card\"\u003e\n      \u003ch3\u003e% Aprobación por edad\u003c/h3\u003e\n      \u003cdiv class\u003d\"meta\"\u003ePromedio por rango etario\u003c/div\u003e\n      \u003cdiv class\u003d\"chart-wrap\"\u003e\u003ccanvas id\u003d\"chartAge\"\u003e\u003c/canvas\u003e\u003c/div\u003e\n    \u003c/div\u003e\n\n    \u003cdiv class\u003d\"card\"\u003e\n      \u003ch3\u003ePromedio vs Mediana por edad (%)\u003c/h3\u003e\n      \u003cdiv class\u003d\"meta\"\u003ePromedio (barra) y mediana (punto)\u003c/div\u003e\n      \u003cdiv class\u003d\"chart-wrap\"\u003e\u003ccanvas id\u003d\"chartAgeAvgMed\"\u003e\u003c/canvas\u003e\u003c/div\u003e\n    \u003c/div\u003e\n\n    \u003cdiv class\u003d\"card\"\u003e\n      \u003ch3\u003e% Aprobación por género\u003c/h3\u003e\n      \u003cdiv class\u003d\"meta\"\u003ePromedio por género\u003c/div\u003e\n      \u003cdiv class\u003d\"chart-wrap\"\u003e\u003ccanvas id\u003d\"chartGender\"\u003e\u003c/canvas\u003e\u003c/div\u003e\n    \u003c/div\u003e\n\n    \u003cdiv class\u003d\"card\"\u003e\n      \u003ch3\u003ePromedio vs Mediana por género (%)\u003c/h3\u003e\n      \u003cdiv class\u003d\"meta\"\u003ePromedio (barra) y mediana (punto)\u003c/div\u003e\n      \u003cdiv class\u003d\"chart-wrap\"\u003e\u003ccanvas id\u003d\"chartGenderAvgMed\"\u003e\u003c/canvas\u003e\u003c/div\u003e\n    \u003c/div\u003e\n\n    \u003cdiv class\u003d\"card\"\u003e\n      \u003ch3\u003eCursos: Promedio (%) y respuestas\u003c/h3\u003e\n      \u003cdiv class\u003d\"meta\"\u003eTop 20 cursos por promedio\u003c/div\u003e\n      \u003cdiv class\u003d\"chart-wrap courses\"\u003e\u003ccanvas id\u003d\"chartCourses\"\u003e\u003c/canvas\u003e\u003c/div\u003e\n    \u003c/div\u003e\n  \u003c/div\u003e\n\n  \u003csection style\u003d\"margin-top:14px;\"\u003e\n    \u003cdiv style\u003d\"display:flex;gap:12px;align-items:flex-start;\"\u003e\n      \u003cdiv style\u003d\"flex:1\"\u003e\n        \u003ch3 style\u003d\"margin:0 0 6px 0; font-size:14px; color:#e5e7eb\"\u003eDepuración / Payload\u003c/h3\u003e\n        \u003cdiv style\u003d\"display:flex; gap:8px; margin-bottom:6px;\"\u003e\n          \u003cbutton id\u003d\"showRawBtn\" class\u003d\"btn ghost\"\u003eMostrar JSON (console)\u003c/button\u003e\n          \u003cbutton id\u003d\"pastePayloadBtn\" class\u003d\"btn ghost\"\u003ePegar payload manual (test)\u003c/button\u003e\n        \u003c/div\u003e\n        \u003cpre id\u003d\"debugPre\" class\u003d\"debug\" style\u003d\"display:none;\"\u003e\u003c/pre\u003e\n      \u003c/div\u003e\n      \u003cdiv style\u003d\"width:340px;\"\u003e\n        \u003ch3 style\u003d\"margin:0 0 6px 0; font-size:14px; color:#e5e7eb\"\u003eMeta / Encabezados\u003c/h3\u003e\n        \u003cpre id\u003d\"metaPre\" class\u003d\"debug\"\u003eSin datos aún.\u003c/pre\u003e\n      \u003c/div\u003e\n    \u003c/div\u003e\n  \u003c/section\u003e\n\n  \u003cscript\u003e\n    /* \u003d\u003d\u003d\u003d\u003d\u003d Tema dark para Chart.js (defaults) \u003d\u003d\u003d\u003d\u003d\u003d */\n    function setDarkChartDefaults(){\n      Chart.defaults.color \u003d \"#cbd5e1\"; // texto general\n      Chart.defaults.font.family \u003d \u0027ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial\u0027;\n      Chart.defaults.plugins.legend.labels.color \u003d \"#cbd5e1\";\n      Chart.defaults.plugins.tooltip.backgroundColor \u003d \"#0b1220\";\n      Chart.defaults.plugins.tooltip.borderColor \u003d \"#1f2937\";\n      Chart.defaults.plugins.tooltip.borderWidth \u003d 1;\n      Chart.defaults.datasets.bar.borderRadius \u003d 6;\n\n      const gridColor \u003d \"rgba(148,163,184,.18)\";\n      const tickColor \u003d \"#94a3b8\";\n      const scaleCommon \u003d { grid: { color: gridColor, drawBorder:false }, ticks: { color: tickColor } };\n      Chart.defaults.scales \u003d {\n        linear: scaleCommon,\n        radialLinear: { grid: { color: gridColor }, angleLines:{ color: gridColor }, pointLabels:{ color:\"#cbd5e1\" }, ticks:{ color: tickColor } },\n        category: { grid:{ color: gridColor, drawBorder:false }, ticks:{ color: tickColor } },\n        time: scaleCommon\n      };\n\n      // Pintar fondo del canvas del color de la tarjeta\n      const bgPlugin \u003d {\n        id: \u0027cardBG\u0027,\n        beforeDraw(chart, args, opts){\n          const {ctx, width, height} \u003d chart;\n          ctx.save();\n          ctx.globalCompositeOperation \u003d \u0027destination-over\u0027;\n          ctx.fillStyle \u003d getComputedStyle(chart.canvas.parentElement).backgroundColor || \u0027#0f172a\u0027;\n          ctx.fillRect(0,0,width,height);\n          ctx.restore();\n        }\n      };\n      Chart.register(bgPlugin);\n    }\n    setDarkChartDefaults();\n\n    /* \u003d\u003d\u003d\u003d\u003d\u003d Lógica original (sin cambios funcionales) \u003d\u003d\u003d\u003d\u003d\u003d */\n    let originalPayload \u003d null, currentPayload \u003d null;\n    let chartDaily\u003dnull, chartDistribution\u003dnull, chartAge\u003dnull, chartAgeAvgMed\u003dnull, chartGender\u003dnull, chartGenderAvgMed\u003dnull, chartCourses\u003dnull;\n\n    function safeNum(v, fallback\u003d0){ const n\u003dNumber(v); return (isFinite(n)\u0026\u0026!isNaN(n))?n:fallback; }\n    function median(values){ if(!values||!values.length) return null; const a\u003d[...values].sort((x,y)\u003d\u003ex-y), m\u003dMath.floor(a.length/2); return a.length%2\u003d\u003d\u003d0?(a[m-1]+a[m])/2:a[m]; }\n    function groupStatsByBucket(students, keyGetter, valueGetter){\n      const buckets\u003d{}; (students||[]).forEach(s\u003d\u003e{ const k\u003dkeyGetter(s)||\u0027No declarado\u0027; const v\u003dsafeNum(valueGetter(s),null);\n        if(!buckets[k]) buckets[k]\u003d{sum:0,count:0,vals:[]}; if(v!\u003d\u003dnull){ buckets[k].sum+\u003dv; buckets[k].count++; buckets[k].vals.push(v); }});\n      return Object.keys(buckets).map(k\u003d\u003e{ const b\u003dbuckets[k]; return {key:k, promedio:b.count?+(b.sum/b.count).toFixed(2):null, mediana:b.vals.length?+median(b.vals).toFixed(2):null, count:b.count}; })\n        .sort((a,b)\u003d\u003e (a.key\u003eb.key?1:-1));\n    }\n\n    function renderStats(payload){\n      const t\u003dpayload.totals||{}, unique\u003d(t.uniqueStudents!\u003dnull)?t.uniqueStudents:(t.totalStudents||0), eight\u003dt.students8Plus||0;\n      const pct \u003d unique ? ((eight/unique)*100).toFixed(1) : \u00270.0\u0027;\n      document.getElementById(\u0027statUnique\u0027).innerText\u003dunique;\n      document.getElementById(\u0027stat8\u0027).innerText\u003deight;\n      document.getElementById(\u0027stat8pct\u0027).innerText\u003d`${pct}% de alumnos únicos`;\n      document.getElementById(\u0027statsRow\u0027).style.display\u003d\u0027grid\u0027;\n    }\n\n    function filterPayloadByDate(payload, dateStr){\n      if(!dateStr) return JSON.parse(JSON.stringify(payload));\n      const studentsFiltered\u003d(payload.students||[]).filter(s\u003d\u003eString(s.Fecha)\u003d\u003d\u003dString(dateStr));\n      const uniqueRuts\u003dnew Set(), maxCursosByRut\u003d{};\n      studentsFiltered.forEach(s\u003d\u003e{ const rut\u003ds.RUT||s.rut||\u0027\u0027; if(!rut) return; uniqueRuts.add(rut); const c\u003dNumber(s.TotalCursos||0); maxCursosByRut[rut]\u003dMath.max(maxCursosByRut[rut]||0,c); });\n      const eightPlusCount\u003dObject.values(maxCursosByRut).filter(v\u003d\u003ev\u003e\u003d8).length;\n      const daily\u003d(payload.dailyActivity||[]).filter(d\u003d\u003ed.date\u003d\u003d\u003ddateStr);\n      const coursesPerStudent \u003d Object.entries(maxCursosByRut).map(([rut, total]) \u003d\u003e ({ RUT: rut, TotalCursos: total }));\n\n      return {\n        totals:{ totalResponses:studentsFiltered.length, totalStudents:uniqueRuts.size, uniqueStudents:uniqueRuts.size, students8Plus:eightPlusCount },\n        dailyActivity:daily,\n        coursesDetected:payload.coursesDetected||[],\n        demographics:payload.demographics||{},\n        students:studentsFiltered,\n        coursesPerStudent,\n        dates:{ labels:daily.map(d\u003d\u003ed.date), total:daily.map(d\u003d\u003ed.uniqueStudents), con8:daily.map(d\u003d\u003ed.students8Plus) },\n        meta:payload.meta||{}\n      };\n    }\n\n    /* Colores para el tema */\n    const C \u003d {\n      blue:   \u0027#60a5fa\u0027,\n      cyan:   \u0027#22d3ee\u0027,\n      green:  \u0027#22c55e\u0027,\n      amber:  \u0027#f59e0b\u0027,\n      violet: \u0027#a78bfa\u0027,\n      red:    \u0027#ef4444\u0027,\n      slate:  \u0027#64748b\u0027\n    };\n\n    function renderDailyActivity(payload){\n      const canvas\u003ddocument.getElementById(\u0027chartDaily\u0027), wrap\u003dcanvas.parentElement;\n      const labels\u003d(payload.dates?.labels)||((payload.dailyActivity||[]).map(d\u003d\u003ed.date));\n      const totals\u003d(payload.dates?.total)||((payload.dailyActivity||[]).map(d\u003d\u003ed.uniqueStudents));\n      const con8   \u003d(payload.dates?.con8)||((payload.dailyActivity||[]).map(d\u003d\u003ed.students8Plus));\n      const px\u003d42, widthPx\u003dMath.max(labels.length*px, wrap.clientWidth), heightPx\u003dwrap.clientHeight||parseInt(getComputedStyle(wrap).height)||260;\n      canvas.style.width\u003dwidthPx+\u0027px\u0027; canvas.style.height\u003dheightPx+\u0027px\u0027; canvas.width\u003dwidthPx; canvas.height\u003dheightPx;\n\n      const data\u003d{ labels, datasets:[\n        {type:\u0027bar\u0027,label:\u0027Alumnos Únicos\u0027,data:totals,backgroundColor:C.blue},\n        {type:\u0027line\u0027,label:\u0027Alumnos ≥8\u0027,data:con8,borderColor:C.red,tension:0.35,fill:false,pointRadius:4,yAxisID:\u0027y\u0027}\n      ]};\n      const options\u003d{ responsive:false, maintainAspectRatio:false, interaction:{mode:\u0027index\u0027,intersect:false},\n        plugins:{legend:{position:\u0027top\u0027}},\n        scales:{ x:{ticks:{autoSkip:false,maxRotation:0,minRotation:0}}, y:{beginAtZero:true,title:{display:true,text:\u0027Alumnos\u0027}} },\n        onClick:(evt)\u003d\u003e{ const pts\u003dchartDaily.getElementsAtEventForMode(evt,\u0027nearest\u0027,{intersect:true},false); if(pts?.length){ const idx\u003dpts[0].index; const date\u003dlabels[idx]; if(date){ document.getElementById(\u0027dateFilter\u0027).value\u003ddate; applyDateFilter(); } } }\n      };\n      if(chartDaily) chartDaily.destroy(); chartDaily\u003dnew Chart(canvas.getContext(\u00272d\u0027),{data,options});\n    }\n\n    function renderDistribution(payload){\n      const base \u003d (payload.coursesPerStudent \u0026\u0026 payload.coursesPerStudent.length)\n        ? payload.coursesPerStudent\n        : (payload.students || []).map(s \u003d\u003e ({ RUT:s.RUT, TotalCursos: Number(s.TotalCursos||0) }));\n\n      const hist \u003d {};\n      base.forEach(s \u003d\u003e { const n \u003d Number(s.TotalCursos || 0); hist[n] \u003d (hist[n] || 0) + 1; });\n\n      const list \u003d Object.entries(hist).map(([c, cnt]) \u003d\u003e ({ cursos: Number(c), alumnos: cnt })).sort((a, b) \u003d\u003e a.cursos - b.cursos);\n      const labels \u003d list.map(r \u003d\u003e String(r.cursos)), dataVals \u003d list.map(r \u003d\u003e r.alumnos);\n\n      const ctx \u003d document.getElementById(\u0027chartDistribution\u0027).getContext(\u00272d\u0027);\n      const data \u003d { labels, datasets: [{ label:\u0027Alumnos\u0027, data:dataVals, backgroundColor:C.cyan }] };\n      const options \u003d { responsive:true, maintainAspectRatio:false, plugins:{ legend:{ display:false } } };\n      if(chartDistribution) chartDistribution.destroy();\n      chartDistribution \u003d new Chart(ctx, { type:\u0027bar\u0027, data, options });\n\n      const mayor \u003d list.length ? list[list.length - 1] : null;\n      document.getElementById(\u0027distSummary\u0027).innerText \u003d mayor ? `Mayor: ${mayor.cursos} cursos → ${mayor.alumnos} alumnos` : \u0027Sin datos\u0027;\n    }\n\n    function renderAgeCharts(payload){\n      const students\u003dpayload.students||[];\n      const byAge\u003dgroupStatsByBucket(\n        students,\n        s\u003d\u003e{ const a\u003ds.Edad??s.edad??null; if(a\u003d\u003d\u003dnull) return \u0027No declarado\u0027; const n\u003dNumber(a); if(isNaN(n)) return \u0027No declarado\u0027; if(n\u003c18) return \u0027\u003c18\u0027; if(n\u003c25) return \u002718-24\u0027; if(n\u003c35) return \u002725-34\u0027; if(n\u003c50) return \u002735-49\u0027; return \u002750+\u0027; },\n        s\u003d\u003es.PromedioNota??s.Promedio??s.promedio\n      );\n      const labels\u003dbyAge.map(b\u003d\u003eb.key), proms\u003dbyAge.map(b\u003d\u003eb.promedio??0), meds\u003dbyAge.map(b\u003d\u003eb.mediana??0);\n      const ctxA\u003ddocument.getElementById(\u0027chartAge\u0027).getContext(\u00272d\u0027); if(chartAge) chartAge.destroy();\n      chartAge\u003dnew Chart(ctxA,{type:\u0027bar\u0027,data:{labels,datasets:[{label:\u0027% Aprobación (promedio)\u0027,data:proms,backgroundColor:C.green}]},options:{responsive:true,maintainAspectRatio:false}});\n      const ctxB\u003ddocument.getElementById(\u0027chartAgeAvgMed\u0027).getContext(\u00272d\u0027); if(chartAgeAvgMed) chartAgeAvgMed.destroy();\n      chartAgeAvgMed\u003dnew Chart(ctxB,{data:{labels,datasets:[{type:\u0027bar\u0027,label:\u0027Promedio (%)\u0027,data:proms,backgroundColor:C.green},{type:\u0027scatter\u0027,label:\u0027Mediana (%)\u0027,data:meds.map((m,i)\u003d\u003e({x:i,y:m})),backgroundColor:C.violet}]},options:{responsive:true,maintainAspectRatio:false,scales:{x:{ticks:{callback:i\u003d\u003elabels[i]}},y:{beginAtZero:true}}}});\n    }\n\n    function renderGenderCharts(payload){\n      const students\u003dpayload.students||[];\n      const byGender\u003dgroupStatsByBucket(students, s\u003d\u003e(s.Género||s.genero||s.gender||\u0027No declarado\u0027), s\u003d\u003es.PromedioNota??s.Promedio??s.promedio );\n      const labels\u003dbyGender.map(b\u003d\u003eb.key), proms\u003dbyGender.map(b\u003d\u003eb.promedio??0), meds\u003dbyGender.map(b\u003d\u003eb.mediana??0);\n      const ctxG\u003ddocument.getElementById(\u0027chartGender\u0027).getContext(\u00272d\u0027); if(chartGender) chartGender.destroy();\n      chartGender\u003dnew Chart(ctxG,{type:\u0027bar\u0027,data:{labels,datasets:[{label:\u0027% Aprobación (promedio)\u0027,data:proms,backgroundColor:C.amber}]},options:{responsive:true,maintainAspectRatio:false}});\n      const ctxH\u003ddocument.getElementById(\u0027chartGenderAvgMed\u0027).getContext(\u00272d\u0027); if(chartGenderAvgMed) chartGenderAvgMed.destroy();\n      chartGenderAvgMed\u003dnew Chart(ctxH,{data:{labels,datasets:[{type:\u0027bar\u0027,label:\u0027Promedio (%)\u0027,data:proms,backgroundColor:C.amber},{type:\u0027scatter\u0027,label:\u0027Mediana (%)\u0027,data:meds.map((m,i)\u003d\u003e({x:i,y:m})),backgroundColor:C.violet}]},options:{responsive:true,maintainAspectRatio:false,scales:{x:{ticks:{callback:i\u003d\u003elabels[i]}},y:{beginAtZero:true}}}});\n    }\n\n    function renderCoursesChart(payload){\n      const canvas\u003ddocument.getElementById(\u0027chartCourses\u0027);\n      const wrap\u003dcanvas.parentElement;\n\n      const list\u003d(payload.coursesDetected||[]).filter(c\u003d\u003ec.avg!\u003d\u003dnull).slice(0,200);\n      const top\u003dlist.sort((a,b)\u003d\u003eb.avg-a.avg).slice(0,20);\n\n      const labels\u003dtop.map(c\u003d\u003ec.course);\n      const avgData\u003dtop.map(c\u003d\u003e+(c.avg||0).toFixed(2));\n      const respData\u003dtop.map(c\u003d\u003ec.responses||0);\n\n      const heightPx\u003dMath.max(labels.length*28+80, 300);\n      canvas.height\u003dheightPx; canvas.style.height\u003dheightPx+\u0027px\u0027;\n      canvas.width\u003dwrap.clientWidth; canvas.style.width\u003d\u0027100%\u0027;\n\n      const data\u003d{ labels,\n        datasets:[\n          { type:\u0027bar\u0027, label:\u0027Promedio (%)\u0027, data:avgData, backgroundColor:C.primary, borderColor:\u0027#93c5fd77\u0027, borderWidth:1, xAxisID:\u0027x\u0027 },\n          { type:\u0027bar\u0027, label:\u0027Respuestas\u0027,   data:respData, backgroundColor:\u0027#64748b55\u0027, xAxisID:\u0027x2\u0027 }\n        ]};\n\n      const options\u003d{\n        indexAxis:\u0027y\u0027,\n        responsive:true, maintainAspectRatio:false,\n        plugins:{ legend:{ position:\u0027top\u0027 }, tooltip:{ callbacks:{ label:(ctx)\u003d\u003e ctx.dataset.label\u003d\u003d\u003d\u0027Promedio (%)\u0027 ? `Promedio: ${ctx.parsed.x}%` : `Respuestas: ${ctx.parsed.x}` } } },\n        scales:{\n          x:  { position:\u0027top\u0027, beginAtZero:true, title:{display:true,text:\u0027Promedio (%)\u0027}, suggestedMax:100 },\n          x2: { position:\u0027bottom\u0027, beginAtZero:true, grid:{drawOnChartArea:false}, title:{display:true,text:\u0027Respuestas\u0027} },\n          y:  { ticks:{ autoSkip:false } }\n        }\n      };\n\n      if(chartCourses) chartCourses.destroy();\n      chartCourses\u003dnew Chart(canvas.getContext(\u00272d\u0027), { data, options });\n    }\n\n    function renderAll(payload){\n      if(!payload) return;\n      document.getElementById(\u0027loader\u0027).style.display\u003d\u0027none\u0027;\n      document.getElementById(\u0027dashboardGrid\u0027).style.display\u003d\u0027grid\u0027;\n      document.getElementById(\u0027metaPre\u0027).innerText\u003dJSON.stringify(payload.meta||{},null,2);\n\n      renderStats(payload);\n      renderDailyActivity(payload);\n      renderDistribution(payload);\n      renderAgeCharts(payload);\n      renderGenderCharts(payload);\n      renderCoursesChart(payload);\n    }\n\n    function fetchPayload(){\n      if(window.google \u0026\u0026 google.script \u0026\u0026 google.script.run){\n        document.getElementById(\u0027loader\u0027).innerText\u003d\u0027Cargando datos desde servidor…\u0027;\n        google.script.run.withSuccessHandler(function(p){\n          originalPayload\u003dp; currentPayload\u003dp; window.dashboardPayload\u003dp; renderAll(currentPayload);\n        }).withFailureHandler(function(err){\n          document.getElementById(\u0027loader\u0027).innerText\u003d\u0027Error cargando datos: \u0027+(err\u0026\u0026err.message?err.message:JSON.stringify(err));\n          console.error(\u0027Error getDashboardData:\u0027,err);\n        }).getDashboardData();\n      } else {\n        document.getElementById(\u0027loader\u0027).innerText\u003d\u0027No se detectó google.script.run. Si estás probando localmente, pega el payload manualmente (botón \"Pegar payload manual\").\u0027;\n      }\n    }\n\n    function applyDateFilter(){\n      const dateVal\u003ddocument.getElementById(\u0027dateFilter\u0027).value;\n      if(!originalPayload) return alert(\u0027Payload no cargado aún.\u0027);\n      currentPayload \u003d dateVal ? filterPayloadByDate(originalPayload,dateVal) : JSON.parse(JSON.stringify(originalPayload));\n      window.dashboardPayload\u003dcurrentPayload;\n      renderAll(currentPayload);\n    }\n    function resetFilter(){ document.getElementById(\u0027dateFilter\u0027).value\u003d\u0027\u0027; currentPayload\u003dJSON.parse(JSON.stringify(originalPayload)); window.dashboardPayload\u003dcurrentPayload; renderAll(currentPayload); }\n\n    function exportData(){\n      const payload\u003dwindow.dashboardPayload||originalPayload; if(!payload) return alert(\u0027No hay datos para exportar.\u0027);\n      const jsonStr\u003dJSON.stringify(payload,null,2); const jBlob\u003dnew Blob([jsonStr],{type:\u0027application/json\u0027}); const jUrl\u003dURL.createObjectURL(jBlob);\n      const a1\u003ddocument.createElement(\u0027a\u0027); a1.href\u003djUrl; a1.download\u003d\u0027dashboard-data.json\u0027; a1.click(); URL.revokeObjectURL(jUrl);\n\n      const students\u003dpayload.students||[];\n      if(students.length){\n        const headers\u003dObject.keys(students[0]);\n        const rows\u003dstudents.map(s\u003d\u003eheaders.map(h\u003d\u003e`\"${String(s[h]??\u0027\u0027).replace(/\"/g,\u0027\"\"\u0027)}\"`).join(\u0027,\u0027));\n        const csv\u003d[headers.join(\u0027,\u0027),...rows].join(\u0027\\n\u0027);\n        const b\u003dnew Blob([csv],{type:\u0027text/csv;charset\u003dutf-8;\u0027});\n        const url\u003dURL.createObjectURL(b);\n        const a2\u003ddocument.createElement(\u0027a\u0027); a2.href\u003durl; a2.download\u003d\u0027students.csv\u0027; a2.click(); URL.revokeObjectURL(url);\n      }\n\n      const courses\u003dpayload.coursesDetected||[];\n      if(courses.length){\n        const headers\u003dObject.keys(courses[0]);\n        const rows\u003dcourses.map(c\u003d\u003eheaders.map(h\u003d\u003e`\"${String(c[h]??\u0027\u0027).replace(/\"/g,\u0027\"\"\u0027)}\"`).join(\u0027,\u0027));\n        const csv\u003d[headers.join(\u0027,\u0027),...rows].join(\u0027\\n\u0027);\n        const b2\u003dnew Blob([csv],{type:\u0027text/csv;charset\u003dutf-8;\u0027});\n        const url2\u003dURL.createObjectURL(b2);\n        const a3\u003ddocument.createElement(\u0027a\u0027); a3.href\u003durl2; a3.download\u003d\u0027coursesDetected.csv\u0027; a3.click(); URL.revokeObjectURL(url2);\n      }\n\n      const cps \u003d payload.coursesPerStudent || [];\n      if (cps.length){\n        const headers \u003d Object.keys(cps[0]);\n        const rows \u003d cps.map(s \u003d\u003e headers.map(h \u003d\u003e `\"${String(s[h] ?? \u0027\u0027).replace(/\"/g,\u0027\"\"\u0027)}\"`).join(\u0027,\u0027));\n        const csv \u003d [headers.join(\u0027,\u0027), ...rows].join(\u0027\\n\u0027);\n        const b3 \u003d new Blob([csv], {type:\u0027text/csv;charset\u003dutf-8;\u0027});\n        const url3 \u003d URL.createObjectURL(b3);\n        const a4 \u003d document.createElement(\u0027a\u0027); a4.href \u003d url3; a4.download \u003d \u0027courses_per_student.csv\u0027; a4.click();\n        URL.revokeObjectURL(url3);\n      }\n\n      alert(\u0027Descarga iniciada (JSON y CSVs si había datos).\u0027);\n    }\n\n    function showRawInConsole(){ console.log(\u0027payload:\u0027, window.dashboardPayload||originalPayload); alert(\u0027Payload impreso en consola (F12 → Console).\u0027); }\n    function promptPastePayload(){ const raw\u003dprompt(\u0027Pega aquí el JSON del payload (útil para pruebas locales):\u0027); if(!raw) return; try{ const p\u003dJSON.parse(raw); originalPayload\u003dp; currentPayload\u003dp; window.dashboardPayload\u003dp; renderAll(currentPayload); document.getElementById(\u0027debugPre\u0027).style.display\u003d\u0027block\u0027; document.getElementById(\u0027debugPre\u0027).innerText\u003dJSON.stringify(p,null,2).slice(0,10000);}catch(err){ alert(\u0027JSON inválido: \u0027+err.message);} }\n\n    document.getElementById(\u0027applyFilterBtn\u0027).addEventListener(\u0027click\u0027, applyDateFilter);\n    document.getElementById(\u0027resetFilterBtn\u0027).addEventListener(\u0027click\u0027, resetFilter);\n    document.getElementById(\u0027exportDataBtn\u0027).addEventListener(\u0027click\u0027, exportData);\n    document.getElementById(\u0027showRawBtn\u0027).addEventListener(\u0027click\u0027, showRawInConsole);\n    document.getElementById(\u0027pastePayloadBtn\u0027).addEventListener(\u0027click\u0027, promptPastePayload);\n\n    fetchPayload();\n    window.applyDateFilterFromConsole\u003dfunction(dateStr){ document.getElementById(\u0027dateFilter\u0027).value\u003ddateStr; applyDateFilter(); };\n  \u003c/script\u003e\n\u003c/body\u003e\n\u003c/html\u003e"}]}